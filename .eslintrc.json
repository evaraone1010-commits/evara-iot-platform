{
  "env": {
    "node": true,
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "plugins": ["unused-imports"],
  "rules": {
    "no-unused-vars": "warn",
    "unused-imports/no-unused-vars": "warn",
    "no-unreachable": "warn",
    "no-constant-condition": "warn"
  }
}
