rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    function customerDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/customers/$(request.auth.uid));
    }

    function customerData() {
      return get(/databases/$(database)/documents/customers/$(request.auth.uid)).data;
    }

    function canReadDeviceData(data) {
      return isSuperAdmin()
        || (customerDoc() && (
          (data.customer_id != null && data.customer_id == request.auth.uid) ||
          (data.community_id != null && customerData().community_id != null && data.community_id == customerData().community_id)
        ));
    }

    function isOwnerOfDevice(deviceId) {
      return canReadRegistryData(get(/databases/$(database)/documents/devices/$(deviceId)).data);
    }

    function canReadRegistryData(data) {
      return isSuperAdmin()
        || (customerDoc() && (
          (data.customer_id != null && data.customer_id == request.auth.uid) ||
          (data.community_id != null && customerData().community_id != null && data.community_id == customerData().community_id)
        ));
    }

    match /devices/{deviceId} {
      allow get: if isSignedIn() && (resource == null || canReadRegistryData(resource.data));
      allow list: if isSignedIn() && canReadRegistryData(resource.data);
      allow write: if isSuperAdmin();

      match /channel_metadata/{metaId} {
        allow get: if isSignedIn() && (resource == null || canReadRegistryData(get(/databases/$(database)/documents/devices/$(deviceId)).data));
        allow list: if isSignedIn() && canReadRegistryData(get(/databases/$(database)/documents/devices/$(deviceId)).data);
        allow write: if isSuperAdmin();
      }
    }

    match /flow_meter/{docId} {
      allow get: if isSignedIn() && (resource == null || canReadDeviceData(resource.data) || isOwnerOfDevice(docId));
      allow list: if isSignedIn() && canReadDeviceData(resource.data);
      allow write: if isSuperAdmin();
    }

    match /evaraflow/{docId} {
      allow get: if isSignedIn() && (resource == null || canReadDeviceData(resource.data) || isOwnerOfDevice(docId));
      allow list: if isSignedIn() && canReadDeviceData(resource.data);
      allow write: if isSuperAdmin();
    }

    match /evaratank/{docId} {
      allow get: if isSignedIn() && (resource == null || canReadDeviceData(resource.data) || isOwnerOfDevice(docId));
      allow list: if isSignedIn() && canReadDeviceData(resource.data);
      allow write: if isSuperAdmin();
    }

    match /evaradeep/{docId} {
      allow get: if isSignedIn() && (resource == null || canReadDeviceData(resource.data) || isOwnerOfDevice(docId));
      allow list: if isSignedIn() && canReadDeviceData(resource.data);
      allow write: if isSuperAdmin();
    }

    match /evaratds/{docId} {
      allow get: if isSignedIn() && (resource == null || canReadDeviceData(resource.data) || isOwnerOfDevice(docId));
      allow list: if isSignedIn() && canReadDeviceData(resource.data);
      allow write: if isSuperAdmin();
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && (resource == null || request.auth.uid == customerId || isSuperAdmin());
      allow list: if isSignedIn() && (request.auth.uid == customerId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    match /superadmins/{adminId} {
      allow get: if isSignedIn() && (resource == null || request.auth.uid == adminId || isSuperAdmin());
      allow list: if isSignedIn() && (request.auth.uid == adminId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }
  }
}