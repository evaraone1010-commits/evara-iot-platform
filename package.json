{
  "name": "evara-one",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "cd backend && npm test",
    "security:setup": "node scripts/setup-git-secrets.js",
    "install:backend": "cd backend && npm install --production",
    "install:client": "cd client && npm install",
    "build:client": "cd client && npm run build",
    "build": "npm run install:backend && npm run install:client && npm run build:client",
    "start": "cd backend && node src/server.js",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd client && npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.4.1"
  }
}
