# Backend runtime configuration template
# Copy to your deployment environment and inject secrets from AWS Secrets Manager.

NODE_ENV=production
PORT=8000
AWS_REGION=ap-south-1
APP_SECRET_ID=prod/myapp/backend
AWS_SECRETS_MANAGER_ENABLED=true

# Non-sensitive config
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
DEBUG_AUTH=false
MULTIPLE_REPLICAS=false
